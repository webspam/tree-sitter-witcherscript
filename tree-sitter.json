{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "witcherscript",
      "camelcase": "WitcherScript",
      "title": "WitcherScript",
      "scope": "source.witcherscript",
      "file-types": ["ws"],
      "injection-regex": "^witcherscript$",
      "class-name": "TreeSitterWitcherscript"
    }
  ],
  "metadata": {
    "version": "0.14.1",
    "license": "MIT",
    "description": "WitcherScript grammar for tree-sitter",
    "authors": [
      {
        "name": "SpontanCombust",
        "url": "https://github.com/SpontanCombust"
      },
      {
        "name": "webspam",
        "url": "https://github.com/webspam"
      }
    ],
    "links": {
      "repository": "https://github.com/webspam/tree-sitter-witcherscript",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
